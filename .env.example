# Copy to .env for local (non-Docker) runs. docker-compose sets these itself.
PORT=3000

# Postgres connection
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=callbacks
DB_LOGGING=false

# Auth session lifetime (hours)
SESSION_TTL_HOURS=24

# Brands accepted in the X-Brand-Id webhook header (comma-separated)
KNOWN_BRANDS=brand-a,brand-b
